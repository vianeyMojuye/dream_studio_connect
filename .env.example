# ── Base de données ────────────────────────────────────────────────────────
# Neon PostgreSQL serverless — obtenir depuis https://neon.tech
# DATABASE_URL : URL PostgreSQL Neon (obtenir depuis neon.tech > Connection Details)
DATABASE_URL="postgresql://neondb_owner:npg_yf9VW1JFUCqS@ep-old-rain-anp7gixa-pooler.c-6.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
DIRECT_URL="postgresql://neondb_owner:npg_yf9VW1JFUCqS@ep-old-rain-anp7gixa.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Authentification (Auth.js v5) ──────────────────────────────────────────
# Générer avec: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# ── Cloudinary CDN ─────────────────────────────────────────────────────────
# Obtenir depuis https://cloudinary.com/console
# CDN configuré sur nœud Lagos ou Johannesburg (NFR23)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Upstash Redis ──────────────────────────────────────────────────────────
# Serverless Redis pour rate limiting + cache sessions + cache recherche
# Obtenir depuis https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── WhatsApp Business API (Meta) ───────────────────────────────────────────
# Obtenir depuis https://developers.facebook.com > WhatsApp Business
# Opt-in explicite requis pour notifications (NFR21)
WHATSAPP_ACCESS_TOKEN="your-whatsapp-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_WEBHOOK_SECRET="your-webhook-hmac-secret"

# ── Orange Money / MTN MoMo ────────────────────────────────────────────────
# APIs officielles uniquement — confirmation serveur obligatoire (NFR11, NFR22)
ORANGE_MONEY_API_KEY="your-orange-money-key"
ORANGE_MONEY_API_URL="https://api.orange.com/orange-money-webpay"
MTN_MOMO_API_KEY="your-mtn-momo-key"
MTN_MOMO_API_URL="https://sandbox.momodeveloper.mtn.com"
MOMO_WEBHOOK_SECRET="your-momo-hmac-secret"

# ── Monitoring & Analytics ─────────────────────────────────────────────────
# Sentry — erreurs runtime
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="dream-studio-connect"

# ── Environnement ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
