#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/c/wamp64/www/dream_studio_connect/node_modules/.pnpm/@dotenvx+dotenvx@1.55.1/node_modules/@dotenvx/dotenvx/node_modules:/proc/cygdrive/c/wamp64/www/dream_studio_connect/node_modules/.pnpm/@dotenvx+dotenvx@1.55.1/node_modules:/proc/cygdrive/c/wamp64/www/dream_studio_connect/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/c/wamp64/www/dream_studio_connect/node_modules/.pnpm/@dotenvx+dotenvx@1.55.1/node_modules/@dotenvx/dotenvx/node_modules:/proc/cygdrive/c/wamp64/www/dream_studio_connect/node_modules/.pnpm/@dotenvx+dotenvx@1.55.1/node_modules:/proc/cygdrive/c/wamp64/www/dream_studio_connect/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@dotenvx+dotenvx@1.55.1/node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js" "$@"
else
  exec node  "$basedir/../../../../../@dotenvx+dotenvx@1.55.1/node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js" "$@"
fi
